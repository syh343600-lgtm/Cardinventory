# Supabase PostgreSQL connection strings for Prisma.
#
# DATABASE_URL is used by the deployed app at runtime.
# Use the Supabase transaction pooler connection string for Vercel/serverless.
# It usually uses port 6543. Add pgbouncer=true for Prisma.
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT_URL is used by Prisma CLI migration commands.
# Use the Supabase direct connection string, or session pooler string on port 5432.
DIRECT_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Vercel Blob read-write token.
# Create/connect a Blob store in Vercel Storage, then copy BLOB_READ_WRITE_TOKEN.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
